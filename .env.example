# Domæne som Traefik router bruger (Dokploy/produktion)
FRONTEND_DOMAIN=powershell.mercantec.tech

# OpenAI — påkrævet for AI-feedback på øvelser
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Kun til lokal docker compose override
FRONTEND_PORT=8080
API_PORT=3000

# Mercantec Auth
# - Lokal dev (npm run dev): læses fra .env ved Vite-start
# - Docker/Dokploy: læses ved container-start → /runtime-config.js (genstart efter ændring)
VITE_AUTH_BASE_URL=https://auth.mercantec.tech
VITE_AUTH_CLIENT_ID=ps1
# Skal matche whitelist EKSAKT (http/https, trailing slash). Prod = https.
VITE_AUTH_REDIRECT_URI=https://ps1.mercantec.tech/auth/callback
# Lokal dev:
# VITE_AUTH_REDIRECT_URI=http://localhost:5173/auth/callback
