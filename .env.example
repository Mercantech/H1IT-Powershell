# Domæne som Traefik router bruger (Dokploy/produktion)
FRONTEND_DOMAIN=powershell.mercantec.tech

# OpenAI — påkrævet for AI-feedback på øvelser
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Kun til lokal docker compose override
FRONTEND_PORT=8080
API_PORT=3000

# Mercantec Auth (SPA — Vite eksponerer kun VITE_* til browseren)
VITE_AUTH_BASE_URL=https://auth.mercantec.tech
VITE_AUTH_CLIENT_ID=demo
# Valgfri — standard er {origin}/auth/callback
# VITE_AUTH_REDIRECT_URI=http://localhost:5173/auth/callback
